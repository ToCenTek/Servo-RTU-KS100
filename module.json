{
  "type": "Serial",
  "name": "Servo RTU KS100",
  "path": "ToCenTek",
  "version": "0.2.0",
  "description": "KS100 \u4f3a\u670d Modbus RTU \u5de5\u5177\u6a21\u5757\nKS100 servo Modbus RTU utility module",
  "hasInput": true,
  "hasOutput": true,
  "hideDefaultCommands": true,
  "hideDefaultParameters": [
    "protocol",
    "messageStructure",
    "customSeparator",
    "firstValueIsTheName"
  ],
  "defaults": {
    "autoAdd": false,
    "Protocol": "Raw",
    "BaudRate": 115200,
    "DataBits": 8,
    "Parity": "None",
    "StopBits": 1
  },
  "scripts": [
    "servoRTU.js"
  ],
  "parameters": {
    "Slave Address": {
      "type": "Integer",
      "hexMode": true,
      "default": 1,
      "min": 1,
      "max": 254,
      "description": "\u4ece\u7ad9\u5730\u5740\nSlave address"
    },
    "Get Communication": {
      "type": "Trigger",
      "description": "\u63a2\u6d4b\u4f3a\u670d\u901a\u4fe1\u53c2\u6570\nProbe servo communication parameters"
    }
  },
  "values": {
    "Communication Information": {
      "type": "Container",
      "collapsed": true,
      "Baud Rate": {
        "type": "String",
        "readOnly": true,
        "description": "\u68c0\u6d4b\u5230\u7684\u4f3a\u670d\u4e32\u53e3\u6ce2\u7279\u7387\nDetected servo serial baud rate"
      },
      "Protocol": {
        "type": "String",
        "readOnly": true,
        "description": "\u68c0\u6d4b\u5230\u7684\u4f3a\u670d\u4e32\u53e3\u6a21\u5f0f\nDetected servo serial mode"
      },
      "Last Response": {
        "type": "String",
        "multiline": true,
        "readOnly": true,
        "description": "\u6700\u540e\u4e00\u6bb5\u6d88\u606f\nRX log"
      }
    }
  },
  "commands": {
    "Send Raw": {
      "menu": "",
      "callback": "sendRaw",
      "description": "\u53d1\u9001\u539f\u59cb Modbus RTU \u547d\u4ee4(\u81ea\u52a8\u8ffd\u52a0 CRC16)\nSend raw Modbus RTU command (auto CRC16)",
      "parameters": {
        "Hex Command": {
          "type": "String",
          "default": "01 03 00 47 00 03",
          "description": "\u4e0d\u542b CRC \u7684\u5341\u516d\u8fdb\u5236\u5b57\u8282\nHex bytes without CRC"
        }
      }
    },
    "Get Communication": {
      "menu": "Settings",
      "callback": "probeCommunication",
      "description": "\u81ea\u52a8\u63a2\u7d22\u4f3a\u670d\u901a\u4fe1\u53c2\u6570\uff1a\u904d\u5386\u6ce2\u7279\u7387 4800~115200, \u68c0\u6d4b\u7ad9\u53f7\u548c\u4e32\u53e3\u6a21\u5f0f\nAuto-detect servo: scan baud 4800~115200, detect slave address and protocol mode",
      "parameters": {
        "Slave Address": {
          "type": "Integer",
          "hexMode": true,
          "description": "\u8981\u63a2\u6d4b\u7684\u4ece\u7ad9\u5730\u5740\nSlave address to probe",
          "default": 1,
          "min": 1,
          "max": 254
        }
      }
    },
    "Set Communication": {
      "menu": "Settings",
      "callback": "setCommunication",
      "description": "\u8bbe\u7f6e\u4f3a\u670d\u4e32\u53e3\u53c2\u6570\nSet servo serial parameters",
      "parameters": {
        "Slave Address": {
          "type": "Integer",
          "hexMode": true,
          "description": "\u8981\u64cd\u4f5c\u7684\u4ece\u7ad9\u5730\u5740\nSlave address",
          "default": 1,
          "min": 1,
          "max": 254
        },
        "Baud Rate": {
          "type": "Enum",
          "default": "\u6ce2\u7279\u7387\nBaud rate",
          "options": {
            "115200": 115200,
            "57600": 57600,
            "38400": 38400,
            "19200": 19200,
            "9600": 9600,
            "4800": 4800,
            "2400": 2400,
            "1200": 1200,
            "600": 600,
            "300": 300
          }
        },
        "Protocol": {
          "type": "Enum",
          "default": "\u534f\u8bae\nProtocol",
          "options": {
            "8 N 1": "8N1",
            "8 N 2": "8N2",
            "8 E 1": "8E1",
            "8 E 2": "8E2",
            "8 O 1": "8O1",
            "8 O 2": "8O2"
          }
        }
      }
    },
    "Set Slave Address": {
      "menu": "Settings",
      "callback": "setSlaveAddress",
      "description": "\u4fee\u6539\u4f3a\u670d\u7ad9\u53f7\nSet servo slave address",
      "parameters": {
        "Slave Address": {
          "type": "Integer",
          "hexMode": true,
          "description": "\u8981\u8bbe\u7f6e\u7684\u4ece\u7ad9\u5730\u5740\nSlave address",
          "default": 1,
          "min": 1,
          "max": 254
        },
        "New Slave Address": {
          "type": "Integer",
          "hexMode": true,
          "description": "\u65b0\u7684\u4ece\u7ad9\u5730\u5740\nNew Slave address",
          "default": 1,
          "min": 1,
          "max": 254
        }
      }
    }
  }
}